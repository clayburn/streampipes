org.apache.streampipes.processors.llm.jvm.multimodel.title=Multi-Model Prompt Processor
org.apache.streampipes.processors.llm.jvm.multimodel.description=Use OpenAI, Anthropic, or Ollama in a multi-shot conversation

modelProvider.title=Model Provider
modelProvider.description=Which LLM provider to use (OpenAI, Anthropic, or Ollama)

modelName.title=Model Name
modelName.description=Exact model string, e.g. "gpt-3.5-turbo", "claude-3-sonnet-20240229", or "llama2"

systemPrompt.title=System Prompt
systemPrompt.description=Sets the assistant’s role or persona (e.g. "You are a helpful coding assistant")

apiKey.title=API Key
apiKey.description=OpenAI or Anthropic API key — leave blank when using Ollama

ollamaUrl.title=Ollama Base URL
ollamaUrl.description=Base URL for your Ollama instance (e.g. "http://localhost:11434")

inputField.title=Input Field
inputField.description=Event field that contains the user’s message

outputField.title=Output Field
outputField.description=Event field that will store the model’s reply

temperature.title=Temperature
temperature.description=Creativity of the response (0 = deterministic, 1 = very creative)

historyMode.title=History Strategy
historyMode.description=How much conversation context to keep: Stateless, Windowed, or Full

windowSize.title=Window Size
windowSize.description=Number of recent (user, assistant) turns to retain when using the Windowed strategy
